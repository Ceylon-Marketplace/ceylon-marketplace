# Database (Supabase)
# Transaction pooler (port 6543) — used by the app at runtime
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?schema=marketplace"
# Session pooler (port 5432) — used by Prisma for migrations
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Redis (Upstash — use rediss:// for TLS)
REDIS_URL="rediss://default:[password]@[host].upstash.io:6379"

# JWT
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_REFRESH_SECRET="change-me-refresh-secret-also-long-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# API
API_PORT=3001
API_URL="http://localhost:3001"
CORS_ORIGIN="http://localhost:3000"

# Web
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="http://localhost:3001"

# S3 / Object Storage
S3_ENDPOINT="https://s3.amazonaws.com"
S3_REGION="ap-southeast-1"
S3_BUCKET="ceylon-marketplace"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# App
NODE_ENV="development"
